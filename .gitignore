# claude-vault: version-control only the portable, reusable config from ~/.claude.
# Strategy: ignore everything by default, then explicitly allow safe config.

# 1) Ignore all top-level entries by default
/*

# 2) Allow repo meta + portable config
!/.gitignore
!/README.md
!/CLAUDE.md
!/settings.json
!/hooks/
/hooks/gitnexus/
!/agents/

# 3) skills/: keep ONLY the authored skill dirs, never the plugin symlinks
#    (gitnexus-* skills are plugin-managed — intentionally not tracked here)
!/skills/
/skills/*
!/skills/design-playbook/
!/skills/goalsmith/
!/skills/opencode-dispatch/
!/skills/self-learning/
!/skills/wrap-up/
!/skills/yagni/
!/skills/zettel-wiki/

# 4) Drop generated python caches
**/__pycache__/
